{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "RavenDb": {
    "Url": "http://ravendb:8080"
  },
  "HoundApi": {
    "BaseUrl": "http://hound-api:8080"
  },
  "Ollama": {
    "BaseUrl": "http://ollama:11434/v1",
    "StrategyModel": "qwen3:14b",
    "DefaultModel": "qwen3.5:9b"
  },
  "Strategy": {
    "DebateEnabled": true,
    "DebateTurnsPerSide": 2
  },
  "Alpaca": {
    "ApiKeyId": "",
    "SecretKey": "",
    "Environment": "Paper"
  },
  "TradingGraph": {
    "Symbols": [],
    "MaxRefinements": 2,
    "MonitorDelaySeconds": 60,
    "MaxDegreeOfParallelism": 1,
    "MinimumConfidence": 0.5,
    "RunIntervalMinutes": 240
  },
  "News": {
    "MaxItems": 10,
    "LookbackHours": 48,
    "HttpTimeoutSeconds": 5,
    "Providers": [ "alpaca", "googlenews", "yahoofinance" ]
  },
  "Sentiment": {
    "MaxMessages": 10,
    "HttpTimeoutSeconds": 5,
    "Providers": [ "stocktwits" ]
  },
  "SoftwareStop": {
    "IntervalSeconds": 60,
    "RunWhenMarketClosed": false
  }
}